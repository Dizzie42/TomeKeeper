# ---- Ollama (running on the host) ----
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ---- Qdrant (running in Docker) ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tabletop

# ---- FastAPI ----
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Retrieval / chunking ----
TOP_K=10
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ---- Notion (optional) ----
# Get a token: https://www.notion.so/my-integrations -> create "Internal" integration
# Then in each Notion page you want indexed: "..." menu -> Connections -> add it
NOTION_TOKEN=

# ---- Phase 2 toggles ----
# Set to 1 to skip the cross-encoder reranker (faster startup, lower precision)
# DISABLE_RERANKER=0